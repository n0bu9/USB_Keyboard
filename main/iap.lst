  60          UINT8 ProgWord( UINT16 Addr, UINT16 Data )
  61          {
  62   1        ROM_ADDR = Addr;
  63   1        ROM_DATA = Data;
  64   1        if ( ROM_STATUS & bROM_ADDR_OK ) {                                           // жУНдљЬеЬ∞еЭАжЬЙжХИ
  65   2          ROM_CTRL = ROM_CMD_WRITE;
  66   2          return( ( ROM_STATUS ^ bROM_ADDR_OK ) & 0x7F );                            // ињФеЫЮзКґжАБ,0x00=success,
             - 0x01=time out(bROM_CMD_TOUT), 0x02=unknown command(bROM_CMD_ERR)
  67   2        }
  68   1        else return( 0x40 );
  69   1      }
  70          /*******************************************************************************
  71          * Function Name  : FlashVerify
  72          * Description    : Flashж†°й™М
  73          * Input          : Addr    иКѓзЙЗзЉЦз®ЛеЬ∞еЭАеЬ∞еЭАпЉМеЬ∞еЭАдЄЇеБґжХ∞еЬ∞еЭА
  74                             pData   зЉЦз®ЛжХ∞жНЃпЉМдї•WORDдЄЇеЯЇеЗЖ
  75                             len     ж†°й™МйХњеЇ¶
  76          * Output         : None
