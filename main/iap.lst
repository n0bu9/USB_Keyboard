 119          void CH55X_IAPDownload( void )
 120          {
 121   1          UINT8  s;
 122   1          UINT16 i;
 123   1          UINT16 len,Data;
 124   1          UINT32 addr;
 125   1          switch( iap_cmd.other.buf[0] )                                  // еИЖжЮРеСљдї§з†Б
 126   1          {
 127   2          case CMD_IAP_PROM:                                              // ISP зЉЦз®ЛеСљдї§
 128   2              len = iap_cmd.program.len>>1;                               //ењЕй°їдЄЇ2зЪДжХіжХ∞еАНпЉМжМЙзЕІеНКе≠
             -ЧињЫи°МжУНдљЬ
 129   2              addr = (iap_cmd.program.addr[0] | (UINT16)iap_cmd.program.addr[1]<<8);
 130   2              SAFE_MOD = 0x55;
 131   2              SAFE_MOD = 0xAA;
 132   2              GLOBAL_CFG |= bCODE_WE | bDATA_WE;                          //еЖЩFlash
 133   2              for( i=0; i!=len; i++ )
 134   2              {
 135   3                  Data = (iap_cmd.program.buf[2*i] | (UINT16)iap_cmd.program.buf[2*i+1]<<8);
 136   3                  s = ProgWord( addr,Data );
 137   3                  addr+=2;
 138   3                  if( s != 0x00 )
 139   3                  {
 140   4                      break;
 141   4                  }
 142   3              }
 143   2              SAFE_MOD = 0x55;
 144   2              SAFE_MOD = 0xAA;
 145   2              GLOBAL_CFG &= ~ ( bCODE_WE | bDATA_WE );
 146   2              CH55X_Respond( s );                                         //ињФеЫЮж†°й™М
 147   2              break;
 148   2          case CMD_IAP_ERASE:                                             // ISP жУ¶йЩ§еСљдї§
 149   2              CH55X_Respond( 0 );
 150   2              break;
 151   2          case CMD_IAP_VERIFY:                                             // ISP ж†°й™МеСљдї§
 152   2              addr = (iap_cmd.verify.addr[0] | (UINT16)iap_cmd.verify.addr[1]<<8);
 153   2              len = iap_cmd.verify.len>>1;                                 // ењЕй°їдЄЇ2зЪДжХіжХ∞еАНпЉМжМЙзЕІе≠Ч
             -ињЫи°МжУНдљЬ
 154   2              s = FlashVerify( addr,&(iap_cmd.verify.buf[0]),iap_cmd.verify.len );
 155   2              CH55X_Respond( s );
 156   2              break;
 157   2          case CMD_IAP_END:                                                // ISP зїУжЭЯеСљдї§
 158   2              SAFE_MOD = 0x55;
 159   2              SAFE_MOD = 0xAA;
 160   2              GLOBAL_CFG |= bSW_RESET;                                     // е§НдљНеНХзЙЗжЬЇ,ињЫеЕ•зФ®жИЈз®ЛеЇП
 161   2              break;
 162   2          default:
 163   2              CH55X_Respond( 0xfe );                                       // жЬ™зЯ•зЪДеСљдї§
 164   2              break;
 165   2          }
 166   1      }
