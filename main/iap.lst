  78                              0x00   ж†°й™МжИРеКЯ
  79                              0xff   ж†°й™Ме§±иі•
  80          *******************************************************************************/
  81          UINT8 FlashVerify( UINT16 Addr, UINT8 *pData, UINT16 len )
  82          {
  83   1          UINT16 i;
  84   1          pCode = (PUINT8C)( Addr );
  85   1          for( i=0; i!=len; i++ )
  86   1          {
  87   2              if( *pData != *pCode )
  88   2              {
  89   3                  return 0xff;
  90   3              }
  91   2              pCode++;
  92   2              pData++;
  93   2          }
  94   1          return 0;
  95   1      }
